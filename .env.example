# Public backend URL used by Expo at build/start time.
# Release builds must point to a reachable HTTPS backend.
EXPO_PUBLIC_API_URL=https://trekking-app-production-9c47.up.railway.app/api/v1

# Required by Mapbox MapView screens. Use a public token that starts with pk.
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=YOUR_EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN

# Android release signing env vars
MYAPP_UPLOAD_STORE_FILE=../keystores/upload-keystore.jks
MYAPP_UPLOAD_KEY_ALIAS=YOUR_UPLOAD_KEY_ALIAS
MYAPP_UPLOAD_STORE_PASSWORD=YOUR_UPLOAD_STORE_PASSWORD
MYAPP_UPLOAD_KEY_PASSWORD=YOUR_UPLOAD_KEY_PASSWORD

# Mapbox Android downloads token for Gradle (secret token that starts with sk.)
MAPBOX_DOWNLOADS_TOKEN=YOUR_MAPBOX_DOWNLOADS_TOKEN
